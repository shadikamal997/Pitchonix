// Activity feed events
model Activity {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String // project_created, document_generated, export_completed, quality_checked, share_accepted
  title       String
  description String?
  metadata    Json? // entity id, name, etc.
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("activities")
}

// Template favourites
model TemplateFavourite {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId String // references Template.id
  createdAt  DateTime @default(now())

  @@unique([userId, templateId])
  @@index([userId])
  @@map("template_favourites")
}

// Project sharing / team access
model ProjectShare {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("viewer") // owner, editor, viewer
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_shares")
}

// Comment threads on projects/slides
model Comment {
  id        String    @id @default(uuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  parentId  String?
  parent    Comment?  @relation("replies", fields: [parentId], references: [id])
  replies   Comment[] @relation("replies")
  resolved  Boolean   @default(false)

  // Anchors (Phase 14 — Collaboration v1) — all optional so existing
  // project-level comments stay valid.
  //   slideId          → pinned to a slide
  //   slideElementId   → pinned to a single element on that slide
  //   pageId           → pinned to a PDF Studio page (for the PDF editor)
  //   anchorX/anchorY  → optional 0..100 % position on the slide for a "pin"
  slideId        String?
  slideElementId String?
  pageId         String?
  anchorX        Float?
  anchorY        Float?

  // Phase 36.1A — mentions. Parsed from content on create/edit and stored
  // as Json so the schema doesn't have to mirror future mention metadata
  // changes. Shape: Array<{ userId: string; displayName: string }>.
  mentions Json?

  // Phase 36.1H — assignment. Threads (parentId = null) can be assigned to a
  // workspace user; replies inherit no assignee. Filterable via "Assigned
  // to me" in the panel.
  assignedToId String?
  assignedTo   User?   @relation("CommentAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  // Phase 36.1E — edit tracking. editedAt is set whenever content changes
  // after creation. deletedAt is set by soft-delete; the row stays so reply
  // threads remain coherent ("[message deleted]").
  editedAt  DateTime?
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([userId])
  @@index([slideId])
  @@index([slideElementId])
  @@index([pageId])
  @@index([assignedToId])
  @@map("comments")
}

// =============================================================================
//  ReviewRequest — Phase 36
//
//  One row per review-assignment on a deck. `requestedBy` (deck owner/editor)
//  asks `reviewer` to approve or request-changes. Reviewer transitions the
//  status; the parent Deck's `reviewStatus` mirrors the latest active request.
//
//  Stored as string status (not Prisma enum) to match the codebase convention
//  used by Deck.status and DeckVersion.type:
//
//    requested         | newly created, reviewer hasn't opened yet
//    in_review         | reviewer has opened the deck
//    approved          | reviewer approved
//    changes_requested | reviewer asked for changes
//    withdrawn         | requester cancelled before reviewer acted
// =============================================================================
model ReviewRequest {
  id            String @id @default(uuid())
  deckId        String
  deck          Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)
  requestedById String
  requestedBy   User   @relation("ReviewRequestRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  reviewerId    String
  reviewer      User   @relation("ReviewRequestReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  status  String    @default("requested")
  message String?
  dueDate DateTime?

  // Set when reviewer first opens the deck in review mode (in_review).
  openedAt  DateTime?
  // Set on approve / request-changes / withdraw.
  decidedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deckId, status])
  @@index([reviewerId, status])
  @@index([requestedById])
  @@map("review_requests")
}

// =============================================================================
//  Phase 39 — Workspaces & Teams
//
//  Org ──┬── Workspace ──┬── Member (user + role)
//        │               ├── Invite (pending email-based)
//        │               ├── Activity (deck/comment/review events)
//        │               ├── Audit (member/role/ownership changes)
//        │               └── Projects
//        └── Workspace ...
//
//  Roles (stored as strings to match the codebase convention):
//     owner | admin | editor | reviewer | viewer
// =============================================================================

model Organization {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  ownerId   String
  owner     User     @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaces Workspace[]

  @@index([ownerId])
  @@map("organizations")
}

model Workspace {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  members    WorkspaceMember[]
  invites    WorkspaceInvite[]
  activities WorkspaceActivity[]
  auditLog   WorkspaceAuditLog[]
  projects   Project[]
  brandKits  BrandKit[] // Phase 37A

  @@index([organizationId])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation("WorkspaceMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  // owner | admin | editor | reviewer | viewer
  role        String    @default("viewer")
  joinedAt    DateTime  @default(now())
  invitedById String?
  invitedBy   User?     @relation("WorkspaceMemberInviter", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, role])
  @@map("workspace_members")
}

model WorkspaceInvite {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String
  role        String    @default("editor")
  // Opaque random token used in the accept URL.
  token       String    @unique
  expiresAt   DateTime
  createdById String
  createdBy   User      @relation("WorkspaceInviteCreator", fields: [createdById], references: [id], onDelete: Cascade)
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([workspaceId, email])
  @@index([email])
  @@map("workspace_invites")
}

model WorkspaceActivity {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // Acting user — null for system-emitted events (rare).
  actorId     String?
  actor       User?     @relation("WorkspaceActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  // Examples: deck.created | deck.updated | comment.added | review.requested
  //           review.approved | review.changes_requested | version.restored
  type        String
  // Optional entity reference (e.g. {kind:'deck', id:'…', name:'…'}).
  entity      Json?
  // Free-form additional context.
  metadata    Json?
  createdAt   DateTime  @default(now())

  @@index([workspaceId, createdAt])
  @@index([workspaceId, type])
  @@map("workspace_activities")
}

model WorkspaceAuditLog {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorId     String
  actor       User      @relation("WorkspaceAuditActor", fields: [actorId], references: [id], onDelete: Cascade)
  // Examples: member.invited | member.removed | member.role_changed
  //           workspace.renamed | ownership.transferred
  action      String
  targetType  String? // 'member' | 'invite' | 'workspace' | 'project' | …
  targetId    String?
  before      Json? // pre-change snapshot
  after       Json? // post-change snapshot
  createdAt   DateTime  @default(now())

  @@index([workspaceId, createdAt])
  @@index([workspaceId, action])
  @@map("workspace_audit_log")
}

// =============================================================================
//  Phase 39.1D — DeckShare
//
//  Explicit per-deck (per-project, since 1 project → 1+ decks) access grants.
//  Used alongside the workspace permission matrix:
//
//    - Project.sharingMode === 'private'   →  only owner has access
//    - Project.sharingMode === 'workspace' →  members inherit via role
//    - Project.sharingMode === 'shared'    →  members inherit + DeckShare grants
//
//  Permission ladder (highest wins when both workspace + share apply):
//    view < comment < review < edit
// =============================================================================
model DeckShare {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  memberId    String // userId — explicit grant to a specific user
  member      User     @relation("DeckShareMember", fields: [memberId], references: [id], onDelete: Cascade)
  // view | comment | review | edit
  permission  String   @default("view")
  createdById String
  createdBy   User     @relation("DeckShareCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, memberId])
  @@index([memberId])
  @@map("deck_shares")
}

// Document version snapshots
model DocumentVersion {
  id            String      @id @default(uuid())
  documentId    String
  document      PdfDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version       Int
  title         String
  pagesSnapshot Json // full snapshot of all pages at this point
  createdAt     DateTime    @default(now())

  @@index([documentId])
  @@map("document_versions")
}

// Uploaded Images (for visual documents and PDFs)
model UploadedImage {
  id String @id @default(uuid())

  // File information
  filename     String
  originalName String
  mimetype     String
  size         Int
  path         String
  url          String

  // Optional user association
  userId String?

  // Metadata
  width  Int?
  height Int?
  tags   String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@map("uploaded_images")
}

// =============================================================================
//  Phase 38 — Advanced PPTX Editing
//
//  Promotes inline JSON conventions to first-class models so the editor + the
//  PPTX import/export pipeline have a shared, queryable contract.
//
//    MasterSlide     — deck-scoped master record (background, default styles,
//                       footer slots, watermark). MasterElement rows attach
//                       via masterSlideId so users can have multiple masters
//                       per deck (cover-master, body-master, divider-master).
//    LayoutTemplate  — workspace-scoped saved layout (slots geometry +
//                       default content). Slides reference one to inherit
//                       structure; "Convert Slide → Layout" snapshots a slide
//                       into a new template.
//    DeckTheme       — workspace-scoped theme tokens (colors, fonts, spacing,
//                       borders, shadows). Distinct from BrandKit: themes are
//                       slide-pure design, brand kits add identity / voice.
//    DeckSection     — first-class section (replaces Slide.metadata.sectionId).
//                       Carries name, color, collapsed, order; powers section
//                       reorder, duplicate, and PPTX section export.
//    ReusableSlide   — library entry for slide / section / component group
//                       reuse across decks.
//    DeckTemplate    — converted-deck template (masters + layouts + themes
//                       + slides). Distinct from existing Template (which is
//                       a coarser generation preset).
// =============================================================================

model MasterSlide {
  id     String @id @default(uuid())
  deckId String
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)

  name       String
  layoutType String   @default("body") // cover|body|divider|appendix|custom
  background Json? // {type, color/gradient/image, opacity}
  // Slot definitions: { logos: bool, footer: bool, pageNumbers: bool, watermark: {...} }
  slots         Json?
  // Default style overrides applied to every linked slide (typography, palette).
  defaultStyles Json?
  // Snapshot of the master element layout for cheap rendering / previewing.
  preview Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  slides    Slide[]

  @@index([deckId])
  @@map("master_slides")
}

model LayoutTemplate {
  id          String  @id @default(uuid())
  workspaceId String?
  name        String
  layoutType  String // title|titleContent|twoColumn|comparison|timeline|sectionDivider|imageLeft|imageRight|dashboard|financial|agenda|custom
  // Slot geometry + default content (one entry per placeholder).
  //   [{ id, role, x, y, w, h, defaultType, placeholder }]
  slots     Json
  thumbnail String?
  // Optional source slide we derived this from (Phase 38B "Convert Slide → Layout").
  sourceSlideId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  slides    Slide[]

  @@index([workspaceId])
  @@index([layoutType])
  @@map("layout_templates")
}

model DeckTheme {
  id          String  @id @default(uuid())
  deckId      String?
  deck        Deck?   @relation(fields: [deckId], references: [id], onDelete: Cascade)
  workspaceId String?
  name        String
  // Theme tokens (Phase 38C):
  //   { colors:{}, fonts:{}, spacing:{}, borders:{}, shadows:{} }
  tokens     Json
  isWorkspace Boolean @default(false)
  thumbnail  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  slides    Slide[]

  @@index([deckId])
  @@index([workspaceId])
  @@map("deck_themes")
}

model DeckSection {
  id     String @id @default(uuid())
  deckId String
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)

  name      String
  color     String? // hex tag color for sidebar
  order     Int     @default(0)
  collapsed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  slides    Slide[]

  @@index([deckId, order])
  @@map("deck_sections")
}

model ReusableSlide {
  id          String  @id @default(uuid())
  userId      String?
  workspaceId String?
  name        String
  description String?
  kind        String  @default("slide") // slide|section|component_group
  // Snapshot payload: full slide(s) + elements + masters reference.
  payload   Json
  thumbnail String?
  tags      String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([workspaceId])
  @@index([kind])
  @@map("reusable_slides")
}

model DeckTemplate {
  id          String  @id @default(uuid())
  workspaceId String?
  sourceDeckId String?
  name        String
  description String?
  thumbnail   String?
  isPublic    Boolean @default(false)
  // Full template payload (masters + layouts + themes + slides skeleton).
  payload Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("deck_templates")
}

// =============================================================================
//  Phase 41.1I — Cross-format conversion lineage.
//
//  Every conversion through /convert produces a ConvertedFile row that
//  records:
//    - The source file (filename + bytes hash; we don't store the binary)
//    - The output binary URL (under uploads/converted/)
//    - Source + target formats
//    - Quality scores at the moment of conversion
//    - A `parentId` pointing at the prior conversion in the chain, so a
//      PDF → DOCX → PPTX → PDF lineage walks naturally.
//
//  Self-referential FK so a single tree can be traversed without joins.
// =============================================================================

model ConvertedFile {
  id            String  @id @default(uuid())
  userId        String?
  workspaceId   String?

  /// Optional FK to the previous ConvertedFile in the lineage chain.
  parentId      String?
  parent        ConvertedFile?  @relation("ConvertedFileLineage", fields: [parentId], references: [id], onDelete: SetNull)
  children      ConvertedFile[] @relation("ConvertedFileLineage")

  sourceFilename String
  sourceFormat   String     // pptx | pdf | docx | … (mirrors SupportedFormat)
  sourceBytes    Int

  targetFormat   String     // pptx | pdf | docx | …
  outputUrl      String     // public URL — for the editor to embed
  /// Phase 41.2D — opaque handle returned by the active storage provider
  /// (local filename / S3 key / GCS object name / Azure blob name).
  /// Nullable for back-compat with pre-41.2 rows where the handle was
  /// derived from outputUrl basename.
  storageHandle  String?
  storageBackend String?    // 'local' | 's3' | 'gcs' | 'azure'
  outputBytes    Int

  /// Convenience copy of the quality report so the UI can render without re-running.
  qualityScore   Int        @default(0)
  qualityReport  Json?

  durationMs     Int        @default(0)
  brandKitId     String?
  notes          String?

  createdAt      DateTime   @default(now())

  @@index([userId])
  @@index([workspaceId])
  @@index([parentId])
  @@map("converted_files")
}

// =============================================================================
//  Phase 42 — CV / Resume / Cover Letter / Portfolio.
//
//  Data model is "profile-first": a user owns one CvProfile that holds all
//  their career data (experience / education / skills / projects / …). From
//  that profile they spin up many CvDocuments — each CV, resume, cover
//  letter, or portfolio variant is its own document with a templateId, a
//  doctype, and section overrides (e.g. job-specific summary).
//
//      CvProfile (1)  ────────────────  CvDocument (many)
//                                          └ templateId → CvTemplate
//
//  CvTemplate is the cross-user template library (50+ designs across
//  Corporate / Modern / Executive / Creative / etc.). Templates carry a
//  `layout` JSON spec the renderer interprets and a `previewUrl`.
//
//  Brand kit propagation: each CvDocument links to a brandKitId; the
//  exporter pulls tokens from BrandKitsService at render time.
// =============================================================================

model CvProfile {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Personal info: { fullName, headline, location, email, phone, website,
  ///   linkedin, github, summary, photoUrl }
  personal      Json?

  /// All long-form sections live as Json arrays so the schema doesn't have
  /// to change every time we add a new credential type. Each entry carries
  /// a stable `id` so reorder / edit / delete keep referential integrity.
  experience    Json?    // Array<{ id, company, role, start, end, location, bullets[] }>
  education     Json?    // Array<{ id, institution, degree, field, start, end, gpa, honors[] }>
  skills        Json?    // Array<{ id, name, category, level }>
  languages     Json?    // Array<{ id, name, proficiency }>
  projects      Json?    // Array<{ id, name, description, role, technologies[], links[], results[] }>
  certifications Json?   // Array<{ id, name, issuer, date, expires, credentialId, url, attachmentUrl }>
  awards        Json?    // Array<{ id, title, issuer, date, description }>
  publications  Json?    // Array<{ id, title, venue, date, url, coauthors }>
  references    Json?    // Array<{ id, name, title, company, email, phone, note }>

  /// Source-of-truth for any LinkedIn / DOCX / PDF import provenance.
  importSource  String?  // 'linkedin' | 'docx' | 'pdf' | null
  importedAt    DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  documents     CvDocument[]

  @@index([userId])
  @@map("cv_profiles")
}

model CvDocument {
  id            String   @id @default(uuid())
  profileId     String
  profile       CvProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  userId        String

  /// 'cv' | 'resume' | 'coverLetter' | 'portfolio'
  doctype       String

  /// Free-form title shown in the dashboard (e.g. "Google Engineering Application").
  title         String

  /// Optional template the document was built against.
  templateId    String?
  template      CvTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  /// Optional brand kit (Phase 42R).
  brandKitId    String?

  /// Document body. Stored as Json so each doctype can have its own shape:
  ///   cv / resume      → { sectionOrder: string[], sectionOverrides: {...},
  ///                          summary?: string, jobTitle?, customSkills? }
  ///   coverLetter      → { greeting, intro, body[], closing, signature, company?, role? }
  ///   portfolio        → { sections: [...], showcaseProjectIds: [...] }
  content       Json

  /// Generated previews + last-known export URLs for the dashboard cards.
  thumbnailUrl  String?
  lastExportUrl String?

  /// Used by the dashboard for grouping (e.g. "Software Engineer" applications).
  variant       String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([profileId])
  @@index([doctype])
  @@map("cv_documents")
}

// =============================================================================
//  Phase 42.4B — CV Analysis Snapshot
//
//  Persisted record of a single run of the CV analyzer (or a job-match,
//  benchmark, variant generation). Used to power Analysis History and
//  Compare. Workspace scoping is inherited through profile.userId.
// =============================================================================
model CvAnalysisSnapshot {
  id           String   @id @default(uuid())
  userId       String
  profileId    String
  /// Optional — set when the snapshot is tied to a specific CvDocument.
  documentId   String?

  /// 'analysis' | 'job-match' | 'benchmark' | 'variants' | 'interview'
  kind         String

  /// 0..100 rolled-up score (mirrors analysisJson.overall) for fast list/sort.
  score        Int?
  atsScore     Int?

  /// Free-form label so users can find a snapshot ("After first cleanup").
  label        String?

  /// Full report payload — shape depends on `kind`. Stored as Json so we can
  /// evolve the report contract without a migration per change.
  analysisJson Json

  /// Snapshot of the profile that produced this report (for restore).
  profileJson  Json?

  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([profileId, createdAt])
  @@index([documentId])
  @@map("cv_analysis_snapshots")
}

model CvTemplate {
  id            String   @id @default(uuid())
  /// 'cv' | 'resume' | 'coverLetter' | 'portfolio' — matches CvDocument.doctype
  doctype       String

  /// Display name + category for the gallery (Corporate / Modern / Executive
  /// / Creative / Minimal / Developer / Designer / Academic / Healthcare /
  /// Consulting / Finance / Sales).
  name          String
  category      String

  /// Layout spec the renderer interprets. Shape is renderer-defined; see
  /// `cv-templates/library.ts` for the seed data.
  layout        Json
  thumbnailUrl  String?

  /// When true, anyone can use it; otherwise it's workspace-scoped.
  isPublic      Boolean  @default(true)
  workspaceId   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  documents     CvDocument[]

  @@index([doctype, category])
  @@index([workspaceId])
  @@map("cv_templates")
}


