// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Email verification
  isVerified              Boolean   @default(false)
  verificationToken       String?   @unique
  verificationTokenExpiry DateTime?

  // Password reset
  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  // Magic link login
  magicLinkToken       String?   @unique
  magicLinkTokenExpiry DateTime?

  // Onboarding
  onboardingCompleted Boolean @default(false)

  // Two-factor authentication
  twoFactorSecret  String?
  twoFactorEnabled Boolean @default(false)

  projects                Project[]
  brandKits               BrandKit[]
  exportTemplates         ExportTemplate[]
  exportJobs              ExportJob[]
  notifications           Notification[]
  activities              Activity[]
  templateFavourites      TemplateFavourite[]
  projectShares           ProjectShare[]
  comments                Comment[]
  // Phase 36.1H — comments where this user is the assignee.
  commentsAssigned        Comment[]           @relation("CommentAssignee")
  savedComponents         SavedComponent[] // Phase 32.75 Tier 2
  // Phase 36 — Review workflow
  reviewRequestsRequested ReviewRequest[]     @relation("ReviewRequestRequester")
  reviewRequestsReviewing ReviewRequest[]     @relation("ReviewRequestReviewer")
  // Phase 39 — Workspaces & teams
  organizationsOwned      Organization[]      @relation("OrganizationOwner")
  workspaceMemberships    WorkspaceMember[]   @relation("WorkspaceMemberUser")
  workspaceInvitesSent    WorkspaceMember[]   @relation("WorkspaceMemberInviter")
  workspaceInvitesCreated WorkspaceInvite[]   @relation("WorkspaceInviteCreator")
  workspaceActivities     WorkspaceActivity[] @relation("WorkspaceActivityActor")
  workspaceAuditEvents    WorkspaceAuditLog[] @relation("WorkspaceAuditActor")
  // Phase 39.1D — explicit per-deck access grants
  deckSharesReceived      DeckShare[]         @relation("DeckShareMember")
  deckSharesCreated       DeckShare[]         @relation("DeckShareCreator")
  // Phase 42 — Career documents
  cvProfiles              CvProfile[]

  @@map("users")
}

model Project {
  id             String  @id @default(uuid())
  userId         String
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  documentType   String  @default("pitch_deck") // pitch_deck, business_plan, proposal, sales_deck, company_profile, marketing_plan, etc.
  documentFormat String  @default("slides") // 'slides' for presentations, 'pdf' for PDF Studio documents
  industry       String?
  status         String  @default("draft") // draft, generated, reviewed, exported
  businessInfo   Json? // Stores all wizard data (problem, solution, market, competitors, etc.)
  audience       String? // investors, customers, partners, internal, board, banks, government
  tone           String? // professional, investor-focused, luxury, bold, simple, technical, corporate

  // Media & Branding
  logoUrl   String? // Company logo URL
  imageUrls String[] // Additional images (products, team, etc.)

  qualityScore Int? // 0-100 Pitchonix Score
  lastEditedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Archiving (soft-delete)
  archivedAt DateTime?

  // Public share link
  publicToken String? @unique

  // Analytics counters
  viewCount   Int @default(0)
  exportCount Int @default(0)

  // Phase 39 — Workspace ownership. Nullable so the auto-backfill can run
  // for pre-existing projects on first boot (every user gets a Personal
  // workspace, all their projects move into it).
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  // Phase 39.1D — Sharing visibility:
  //   private   → only the owner can access (workspace role ignored)
  //   workspace → workspace members inherit access via their role
  //   shared    → workspace members PLUS explicit DeckShare grants
  sharingMode String @default("workspace")

  decks          Deck[]
  pdfDocuments   PdfDocument[] // PDF Studio documents
  generationJobs GenerationJob[]
  qualityReports QualityReport[]
  shares         ProjectShare[]
  deckShares     DeckShare[]
  comments       Comment[]

  @@index([workspaceId])
  @@map("projects")
}

model Deck {
  id          String    @id @default(uuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templateId  String?
  template    Template? @relation(fields: [templateId], references: [id])
  brandKitId  String?
  brandKit    BrandKit? @relation(fields: [brandKitId], references: [id])
  title       String
  description String?
  status      String    @default("draft") // draft, generating, ready, exporting
  metadata    Json? // Store additional metadata

  // Quality Control fields (Phase 7/8)
  qualityScore      Json? // QualityScore object with overall, grade, dimensions, breakdown
  validationResult  Json? // ValidationResult object with errors, warnings, info
  generationMetrics Json? // GenerationMetrics with timing, stages, performance
  lastQualityCheck  DateTime? // When quality was last checked
  exportReady       Boolean   @default(false) // Whether deck passes quality checks for export

  // Phase 32.75 — Master Elements & deck-wide design settings.
  //   masterSettings: { showPageNumbers, showLogo, showFooter, showDate, showWatermark }
  // Switches let users hide whole master families without deleting the rows.
  masterSettings Json?

  // Phase 36 — Review workflow state.
  //   draft | in_review | approved | changes_requested
  // Updated by the reviews service whenever a ReviewRequest transitions
  // (request → in_review; approve → approved; request-changes → changes_requested).
  // Edits to deck content after approval flip back to draft (Phase 36I warning surface).
  reviewStatus String @default("draft")

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  slides         Slide[]
  exports        Export[]
  qualityHistory QualityHistory[] // Phase 10: Quality tracking over time
  masterElements MasterElement[] // Phase 32.75
  versions       DeckVersion[] // Phase 35
  reviewRequests ReviewRequest[] // Phase 36

  // Phase 38 — first-class masters / themes / sections backrefs.
  // (LayoutTemplate is workspace-scoped — no deck backref.)
  masterSlides MasterSlide[]
  themes       DeckTheme[]
  sections     DeckSection[]

  @@index([projectId])
  @@index([exportReady])
  @@index([lastQualityCheck])
  @@map("decks")
}

// =============================================================================
//  DeckVersion — Phase 35
//
//  Immutable snapshot of a deck at a point in time. Auto-created by the
//  generation pipeline (GENERATE / REGENERATE / FAMILY_SWITCH / etc.) and
//  before destructive editor actions; can also be created manually via
//  "Save Version" in the editor.
//
//  `snapshot` carries the full deck state needed to restore: slides,
//  elements, masters, component-instances, theme tokens, framework/quality
//  scores. Stored as Json so the schema doesn't have to mirror every
//  downstream change — restore walks the JSON and replays inserts.
// =============================================================================
model DeckVersion {
  id     String  @id @default(uuid())
  deckId String
  deck   Deck    @relation(fields: [deckId], references: [id], onDelete: Cascade)
  userId String? // null for system-generated snapshots (pipeline auto-saves)

  name        String // "Before regenerate" | "Final pitch deck" | …
  description String?
  type        String // AUTO_SAVE | MANUAL_SNAPSHOT | GENERATED | REGENERATED | RESTORED | FAMILY_CHANGED | TEMPLATE_CHANGED | EXPORTED | SAFETY

  // Snapshot payload — full deck state at capture time.
  snapshot Json

  // Lightweight metadata kept out of `snapshot` for quick listing / filtering.
  slideCount   Int     @default(0)
  qualityScore Int? // 0..100 if known
  familyId     String? // composition family at capture time
  templateId   String?

  createdAt DateTime @default(now())

  @@index([deckId, createdAt])
  @@index([deckId, type])
  @@map("deck_versions")
}

// =============================================================================
//  SavedComponent — Phase 32.75 Tier 2
//
//  User-scoped reusable component library. Stores the canonical element tree
//  (a list of SlideElement-shaped rows), plus metadata for browsing (name,
//  category, tags, favourite, usage count, thumbnail).
//
//  `version` bumps every time the source elementTree is edited. Instances
//  store their last-acknowledged version so the editor can flag "update
//  available" without forcing a sync.
// =============================================================================
model SavedComponent {
  id          String  @id @default(uuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String?

  name        String
  description String?
  category    String // see ComponentCategory union in TS types
  thumbnail   String? // data URL or hosted image
  familyId    String? // optional composition family this component looks best in
  tags        String[] @default([])
  favorite    Boolean  @default(false)
  usageCount  Int      @default(0)
  version     Int      @default(1) // bumped every time elementTree changes

  // Source-of-truth element list. Each entry is a SlideElement-shaped object
  // whose x/y are interpreted as offsets from the instance anchor at insert
  // time. Stored as JSON because the editor's element shapes are polymorphic.
  elementTree Json

  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  instances ComponentInstance[]

  @@index([userId, category])
  @@index([userId, favorite])
  @@index([userId, updatedAt])
  @@map("saved_components")
}

// =============================================================================
//  ComponentInstance — Phase 32.75 Tier 2
//
//  One row per "linked" placement of a component on a slide. Static (copy-on-
//  insert) placements DO NOT create a row — they just put plain SlideElement
//  rows on the slide. So the presence of an instance row implies linked mode.
//
//  At render time the slide-export pipeline looks up each instance's
//  component, snapshots its current elementTree, translates by anchor, and
//  injects those elements alongside the slide's own elements. This is how
//  edits to a component propagate to every instance instantly.
//
//  `version` here is the component version the user has *acknowledged*.
//  When component.version > instance.version, the editor surfaces an
//  "Update available" indicator (rendering still uses latest).
// =============================================================================
model ComponentInstance {
  id          String         @id @default(uuid())
  componentId String
  component   SavedComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  slideId     String
  slide       Slide          @relation(fields: [slideId], references: [id], onDelete: Cascade)

  anchorX Float @default(0) // top-left anchor (% of slide W)
  anchorY Float @default(0)
  scale   Float @default(1) // future-proof for resize-on-insert

  version   Int      @default(1) // acknowledged source version
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slideId])
  @@index([componentId])
  @@map("component_instances")
}

// =============================================================================
//  MasterElement — Phase 32.75
//
//  Deck-wide "appears on every slide" element. The render pipeline merges
//  these into each slide's element list before rasterising, so they show in
//  the editor and in every export path (PPTX / PDF / PNG / JPEG) without the
//  per-slide tables having to know about them.
//
//  type covers the canonical master families plus an open `custom` bucket.
//  excludedSlides is a list of slide IDs where the master is suppressed
//  (title slide, divider sections, etc).
// =============================================================================
model MasterElement {
  id     String @id @default(uuid())
  deckId String
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)

  type String // logo|companyName|header|footer|pageNumber|date|copyright|watermark|backgroundShape|backgroundImage|brandBanner|contact|confidential|custom
  name String?

  // Geometry — same 0..100 percent grid as SlideElement so masters can share
  // the renderer plumbing without coordinate translation.
  x           Float   @default(0)
  y           Float   @default(0)
  width       Float   @default(20)
  height      Float   @default(5)
  rotation    Float   @default(0)
  zIndex      Int     @default(0)
  sendToFront Boolean @default(false) // false = render under slide content (default), true = render above

  // Visibility
  visible        Boolean  @default(true)
  excludedSlides String[] @default([]) // slide IDs where this master is hidden

  // Polymorphic payload (matches SlideElement.content shape)
  elementData Json?
  style       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deckId])
  @@index([deckId, type])
  @@map("master_elements")
}

model Slide {
  id           String  @id @default(uuid())
  deckId       String
  deck         Deck    @relation(fields: [deckId], references: [id], onDelete: Cascade)
  type         String // cover, problem, solution, market_size, tam_sam_som, business_model, revenue_streams, traction, customer_segment, competitor_analysis, competitive_advantage, go_to_market, roadmap, team, financial_projection, use_of_funds, investment_ask, closing, appendix
  order        Int
  title        String
  subtitle     String?
  content      Json // Legacy flexible JSON. Kept for back-compat after element-migration; not authoritative once `elementsVersion >= 1`.
  layoutKey    String? // Which template layout to use
  themeKey     String? // Which theme to apply
  speakerNotes String? // Speaker notes
  qualityScore Int? // Individual slide quality score

  // Element-based editing system (Phase 1 of slide editor rebuild)
  elementsVersion    Int                 @default(0) // 0 = not migrated, 1+ = element rows are authoritative
  background         Json? // {type, color/gradient/image, opacity}
  themeTokens        Json? // per-slide theme override
  metadata           Json? // free-form (e.g. groupId, sectionId, animationDuration)
  elements           SlideElement[]
  componentInstances ComponentInstance[] // Phase 32.75 Tier 2

  // Phase 38 — first-class section + master + layout + theme + transition.
  //   sectionId / masterSlideId / layoutTemplateId / themeId are nullable so
  //   existing decks keep working; population happens on opt-in upgrade.
  //   transition: { effect: 'fade'|'push'|'reveal'|'morph'|'cover', duration }.
  sectionId        String?
  section          DeckSection?    @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  masterSlideId    String?
  masterSlide      MasterSlide?    @relation(fields: [masterSlideId], references: [id], onDelete: SetNull)
  layoutTemplateId String?
  layoutTemplate   LayoutTemplate? @relation(fields: [layoutTemplateId], references: [id], onDelete: SetNull)
  themeId          String?
  theme            DeckTheme?      @relation(fields: [themeId], references: [id], onDelete: SetNull)
  transition       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deckId, order])
  @@index([sectionId])
  @@index([masterSlideId])
  @@map("slides")
}

// =============================================================================
//  SlideElement — atomic editable unit on a slide
//
//  Every visible thing on a slide is one row here: heading, paragraph, each
//  bullet item, chart, table cell group, image, shape, icon, etc.
//
//  Polymorphic content via three JSON columns:
//    content  — primary user-facing content for this element type
//               (e.g. {text} for heading, {items: [...]} for bulletList,
//                     {type:'bar',title,datasets:[...]} for chart)
//    data     — supplementary structured data (e.g. table cells, chart
//               categories/axes, KPI value+delta)
//    style    — typography / fill / stroke / shadow / opacity / radius
//               (always per-element; theme tokens are merged at render time)
// =============================================================================
model SlideElement {
  id      String @id @default(uuid())
  slideId String
  slide   Slide  @relation(fields: [slideId], references: [id], onDelete: Cascade)

  type  String // heading|subheading|paragraph|bulletList|numberedList|quote|testimonial|metric|kpi|chart|table|image|icon|logo|shape|line|divider|timeline|roadmap|teamCard|pricingCard|comparison|swot|featureGrid|processSteps|cta|footer|pageNumber|videoPlaceholder|embeddedMediaPlaceholder
  name  String? // user-editable label ("Hero Title", "Market Stat #2")
  order Int // stable iteration order; canvas z-stack uses zIndex

  // Geometry (in slide-local coordinates, 0..100 as % of slide W/H so layouts are resolution-independent)
  x        Float @default(0)
  y        Float @default(0)
  width    Float @default(50)
  height   Float @default(10)
  rotation Float @default(0) // degrees
  zIndex   Int   @default(0)

  // Display flags
  locked  Boolean @default(false)
  visible Boolean @default(true)

  // Polymorphic payload — see comment block above
  content       Json?
  data          Json?
  style         Json?
  animations    Json?
  accessibility Json? // {altText, role, ariaLabel}

  // Phase 34.2B — Y.Doc state for collaborative text elements.
  //   - Holds Y.encodeStateAsUpdate() for any element whose text is being
  //     CRDT-edited (headings, paragraphs, lists, etc.).
  //   - Server-side YDocStore writes this debounced (~2s) after Y updates.
  //   - On first room-join with no row, the gateway seeds the Y.Doc from
  //     `content` so existing decks "upgrade" lazily on first collaboration.
  //   - `content` remains the canonical export source; YDocStore mirrors
  //     into `content` (as a ProseMirror JSON serialisation) on each persist.
  ydocState Bytes?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slideId, order])
  @@index([slideId, type])
  @@map("slide_elements")
}

model Template {
  id          String   @id @default(uuid())
  name        String
  description String?
  thumbnail   String? // URL to template preview image
  isPublic    Boolean  @default(true)
  config      Json // Template configuration (colors, fonts, layout)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  decks       Deck[]

  @@map("templates")
}

model BrandKit {
  id             String     @id @default(uuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Phase 37A — workspace ownership. Nullable for the one-time backfill;
  // new kits are required to belong to a workspace.
  workspaceId    String?
  workspace      Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  name           String
  description    String? // Phase 37A
  isDefault      Boolean    @default(false) // Phase 37A — one default per workspace
  logo           String? // URL to logo
  primaryColor   String? // Hex color
  secondaryColor String? // Hex color
  fontFamily     String?
  config         Json? // Additional brand settings (legacy)
  // Phase 37C/D/E — rich design tokens (colors, typography, spacing,
  // chart styles, etc.). Stored as Json so we can iterate the shape
  // without schema migrations every time.
  //   {
  //     colors: { primary, secondary, accent, success, warning, danger, neutral }
  //     typography: { heading: { family, weight, lineHeight, letterSpacing },
  //                   body: {...}, caption: {...} }
  //     tokens: { borderRadius, shadowStyle, spacingScale, containerWidth, buttonStyle }
  //     chart:  { palette[], axisColor, gridColor, legendStyle }
  //     icon:   { style }
  //   }
  tokens         Json?
  // Phase 37I — writing-voice profile for the generation pipeline.
  //   { tone, voice, rules[], examples[] }
  voice          Json?
  // Phase 37A — brand identity strings used by generation + cover slides.
  //   { companyName, tagline, mission, vision, website }
  identity       Json?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  decks        Deck[]
  pdfDocuments PdfDocument[] // PDF documents using this brand kit
  assets       BrandAsset[] // Phase 37B/R — managed logos + image assets

  @@index([workspaceId])
  @@index([workspaceId, isDefault])
  @@map("brand_kits")
}

// =============================================================================
//  Phase 37B/R — BrandAsset
//
//  Managed logo + image assets attached to a BrandKit. Each asset has a
//  `kind` slot (primary logo, secondary logo, monochrome, dark, light,
//  icon mark, favicon, generic image) so the brand-apply engine knows
//  which slot it fills.
//
//  Stored as URL pointers (the upload pipeline writes to /uploads/images
//  and returns a public URL). Width/height are captured at upload time
//  for layout decisions.
// =============================================================================
model BrandAsset {
  id         String   @id @default(uuid())
  brandKitId String
  brandKit   BrandKit @relation(fields: [brandKitId], references: [id], onDelete: Cascade)
  // logo_primary | logo_secondary | logo_mono | logo_dark | logo_light
  // | icon_mark | favicon | image
  kind       String
  url        String
  mimeType   String?
  width      Int?
  height     Int?
  alt        String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([brandKitId, kind])
  @@map("brand_assets")
}

model Export {
  id        String   @id @default(uuid())
  deckId    String
  deck      Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  format    String // pptx, pdf
  status    String   @default("pending") // pending, processing, completed, failed
  fileUrl   String? // URL to exported file
  error     String? // Error message if failed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("exports")
}

model GenerationJob {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status    String   @default("queued") // queued, processing, generating_outline, generating_slides, applying_design, checking_quality, completed, failed
  progress  Int      @default(0) // 0-100
  result    Json? // Generated content result
  error     String? // Error message if failed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("generation_jobs")
}

model QualityReport {
  id           String   @id @default(uuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  overallScore Int // 0-100 overall Pitchonix Score
  breakdown    Json // Scores by category (clarity, investor_readiness, design, business_logic, market_strength, financial_completeness, story_flow)
  issues       Json // Array of issues with severity (low, medium, high)
  suggestions  Json // Array of suggested fixes
  fixedIssues  Json? // Array of issues that were auto-fixed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("quality_reports")
}

// Phase 10: Export Templates
model ExportTemplate {
  id          String  @id @default(uuid())
  name        String
  description String?
  type        String // 'system' or 'custom'
  format      String // 'pptx', 'pdf', 'html'

  // Template configuration
  config Json // Template-specific settings

  // Branding
  logoUrl   String?
  watermark String?
  colors    Json? // Color palette
  fonts     Json? // Font settings

  // Metadata
  isDefault Boolean @default(false)
  isPublic  Boolean @default(false)
  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  exportJobs ExportJob[]

  @@index([userId])
  @@index([type])
  @@index([format])
  @@map("export_templates")
}

// Phase 10: Quality History Tracking
model QualityHistory {
  id     String @id @default(uuid())
  deckId String
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)

  // Quality metrics
  overallScore Float
  grade        String
  contentScore Float
  visualScore  Float
  aiScore      Float
  exportScore  Float

  // Validation results
  validationPassed Boolean
  errorCount       Int     @default(0)
  warningCount     Int     @default(0)
  infoCount        Int     @default(0)

  // Context
  trigger String // 'generation', 'manual', 'scheduled'
  version Int    @default(1)
  changes Json? // What changed since last check

  createdAt DateTime @default(now())

  @@index([deckId])
  @@index([createdAt])
  @@map("quality_history")
}

// Phase 10: Batch Export Jobs
model ExportJob {
  id      String   @id @default(uuid())
  deckIds String[] // Support batch export
  format  String // 'pptx', 'pdf', 'html'

  // Template and options
  templateId String?
  template   ExportTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  options    Json // Export-specific options

  // Status
  status      String // 'pending', 'processing', 'completed', 'failed'
  progress    Int     @default(0)
  currentDeck String?

  // Results
  outputUrls String[] // Generated file URLs
  errors     Json?

  // Metadata
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("export_jobs")
}

// ===== PDF STUDIO MODELS =====

// PDF Documents (distinct from slide decks)
model PdfDocument {
  id        String  @id @default(uuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Document info
  title        String
  description  String?
  documentType String // business_plan, proposal, company_profile, executive_summary, marketing_plan, etc.

  // Template & Layout
  proTemplateId String? // Pro template identifier
  templateType  String? // Standard template type
  layoutType    String? // Document layout style

  // Design
  brandKitId  String?
  brandKit    BrandKit? @relation(fields: [brandKitId], references: [id])
  brandColor  String? // Primary brand color (hex)
  accentColor String? // Secondary accent color (hex)

  // Content & Structure
  outline  Json? // Document outline/structure
  metadata Json? // Additional metadata

  // Status & Quality
  status           String    @default("draft") // draft, generating, ready, exporting
  qualityScore     Float? // 0-100
  validationResult Json? // Validation results
  exportReady      Boolean   @default(false)
  lastQualityCheck DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  pages               PdfPage[]
  exports             PdfExport[]
  qualityHistory      PdfQualityHistory[]
  contentAnalysis     ContentAnalysis?
  smartBuilderConfig  SmartBuilderConfig?
  contentEnhancements ContentEnhancement[]
  versions            DocumentVersion[]

  @@index([projectId])
  @@index([documentType])
  @@index([status])
  @@index([exportReady])
  @@map("pdf_documents")
}

// Individual PDF Pages
model PdfPage {
  id         String      @id @default(uuid())
  documentId String
  document   PdfDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Page info
  order      Int
  pageNumber Int? // Actual page number in document (may differ from order)
  pageType   String // cover, toc, executive_summary, section_divider, content, metrics, chart, financial_table, timeline, case_study, conclusion
  title      String?

  // Content & Structure
  content           Json // Page-specific content based on template
  blocks            Json? // Structured block content
  semanticSectionId String? // Semantic grouping identifier

  // Template & Design
  templateId   String?
  template     PdfTemplate? @relation(fields: [templateId], references: [id])
  customStyles Json? // Custom styling overrides
  styles       Json? // Page-level styles (separate from customStyles)
  layoutType   String? // Page layout type (single-column, two-column, etc.)
  densityScore Float? // Page density metric (0-100)

  // Quality & Status
  qualityScore     Float? // Individual page quality score
  validationIssues Json? // Page-specific validation issues

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([documentId, order])
  @@index([pageType])
  @@map("pdf_pages")
}

// PDF Page Templates
model PdfTemplate {
  id String @id @default(uuid())

  // Template info
  name        String
  description String?
  pageType    String // cover, toc, executive_summary, etc.
  thumbnail   String? // Preview image URL

  // Template config
  structure      Json // Page structure/layout definition
  defaultContent Json? // Default content values
  styleConfig    Json? // Styling configuration

  // Metadata
  isSystem Boolean  @default(false) // System vs custom template
  isPublic Boolean  @default(false)
  tags     String[] // Searchable tags

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  pages PdfPage[]

  @@index([pageType])
  @@index([isSystem])
  @@map("pdf_templates")
}

// PDF Export Records
model PdfExport {
  id         String      @id @default(uuid())
  documentId String
  document   PdfDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Export config
  format  String @default("pdf") // pdf (could support html, docx in future)
  options Json? // Export options (page size, margins, etc.)

  // Status
  status   String @default("pending") // pending, processing, completed, failed
  progress Int    @default(0) // 0-100

  // Result
  fileUrl   String? // Generated PDF URL
  fileSize  Int? // File size in bytes
  pageCount Int? // Number of pages
  error     String? // Error message if failed

  // Timestamps
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([documentId])
  @@index([status])
  @@index([createdAt])
  @@map("pdf_exports")
}

// PDF Quality History (similar to QualityHistory for decks)
model PdfQualityHistory {
  id         String      @id @default(uuid())
  documentId String
  document   PdfDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Quality metrics
  overallScore      Float
  grade             String
  contentScore      Float
  designScore       Float
  structureScore    Float
  professionalScore Float

  // Validation results
  validationPassed Boolean
  errorCount       Int     @default(0)
  warningCount     Int     @default(0)
  infoCount        Int     @default(0)

  // Context
  trigger String // 'generation', 'manual', 'scheduled'
  version Int    @default(1)
  changes Json? // What changed since last check

  createdAt DateTime @default(now())

  @@index([documentId])
  @@index([createdAt])
  @@map("pdf_quality_history")
}

// ===== SMART PDF BUILDER MODELS =====

// Content Analysis for raw input
model ContentAnalysis {
  id         String       @id @default(uuid())
  documentId String?      @unique
  document   PdfDocument? @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Raw input
  rawContent    String @db.Text // Original raw content
  contentLength Int // Character count

  // Auto-detection results
  detectedType    String // business, academic, report, article, notes, technical, mixed, unknown
  confidence      Float // 0-1 confidence score
  primaryLanguage String @default("en")

  // Content classification
  categories String[] // Tags/categories detected
  keywords   String[] // Key terms extracted
  topics     String[] // Main topics identified

  // Structure analysis
  hasTitle       Boolean @default(false)
  hasHeadings    Boolean @default(false)
  hasBullets     Boolean @default(false)
  hasNumbers     Boolean @default(false)
  sectionCount   Int     @default(0)
  paragraphCount Int     @default(0)

  // Content quality
  readabilityScore Float? // Flesch reading ease score
  grammarIssues    Int    @default(0)
  spellingIssues   Int    @default(0)
  clarityScore     Float? // 0-1 clarity score

  // Extracted information
  extractedData     Json? // Structured data extracted (names, dates, numbers, etc.)
  suggestedTitle    String?
  suggestedSections Json? // Recommended section structure

  // Processing metadata
  processingTime Int? // Processing time in ms
  aiModel        String? // Which AI model was used

  createdAt DateTime @default(now())

  @@index([detectedType])
  @@index([createdAt])
  @@map("content_analyses")
}

// Smart Builder Configuration (user preferences for content transformation)
model SmartBuilderConfig {
  id         String      @id @default(uuid())
  documentId String      @unique
  document   PdfDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // User selections
  documentGoal   String? // inform, persuade, report, educate, pitch, document
  targetAudience String? // executives, investors, clients, team, public, academic
  tone           String // formal, casual, academic, persuasive, technical, friendly
  designStyle    String // minimal, modern, corporate, creative, academic, bold

  // Content transformation preferences
  improveWriting     Boolean @default(true)
  fixGrammar         Boolean @default(true)
  addStructure       Boolean @default(true)
  generateIntro      Boolean @default(false)
  generateSummary    Boolean @default(false)
  generateConclusion Boolean @default(false)
  expandContent      Boolean @default(false)
  shortenContent     Boolean @default(false)

  // Layout preferences
  includeTableOfContents Boolean @default(true)
  includeCoverPage       Boolean @default(true)
  includePageNumbers     Boolean @default(true)
  includeHeaders         Boolean @default(true)
  includeFooters         Boolean @default(true)

  // Advanced options
  customInstructions String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("smart_builder_configs")
}

// Content Enhancement History (track content improvements)
model ContentEnhancement {
  id         String      @id @default(uuid())
  documentId String
  document   PdfDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Enhancement details
  enhancementType String // improve_writing, fix_grammar, restructure, expand, shorten, professionalize, engage
  scope           String // full_document, single_section, single_page
  targetId        String? // Page or section ID if applicable

  // Content before/after
  originalContent String @db.Text
  enhancedContent String @db.Text
  changes         Json? // Detailed changes made

  // Quality impact
  qualityBefore Float?
  qualityAfter  Float?
  improvement   Float? // Percentage improvement

  // Metadata
  aiModel        String?
  processingTime Int? // ms
  userAccepted   Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([documentId])
  @@index([enhancementType])
  @@index([createdAt])
  @@map("content_enhancements")
}

// ===== NEW FEATURE MODELS =====

// In-app notifications
model Notification {
